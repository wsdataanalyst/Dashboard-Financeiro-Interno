# Streamlit Cloud: Settings -> Secrets
# Cole o conteúdo deste arquivo (ajuste valores).

# Tempo de sessão (segundos). Ex: 1800 = 30min
STREAMLIT_SESSION_TIMEOUT = "1800"

# Caminho do banco (apenas se você estiver usando volume persistente / self-host).
# No Streamlit Cloud, o filesystem é efêmero; prefira um banco externo.
DB_PATH = "cobranca.db"

