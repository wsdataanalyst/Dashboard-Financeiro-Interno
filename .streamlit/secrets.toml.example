# Streamlit Cloud: Settings -> Secrets
# Cole o conteúdo deste arquivo (ajuste valores).

# Tempo de sessão (segundos). Ex: 1800 = 30min
STREAMLIT_SESSION_TIMEOUT = "1800"

# Bootstrap de usuários (obrigatório para produção).
# Opção A: BOOTSTRAP_USERS_JSON (recomendado)
# Exemplo:
# BOOTSTRAP_USERS_JSON = '[{"nome":"Admin","email":"admin@empresa.com","senha":"UmaSenhaForte!23","perfil":"supervisor"}]'
#
# Opção B: BOOTSTRAP_USERS (lista TOML)
# [[BOOTSTRAP_USERS]]
# nome = "Admin"
# email = "admin@empresa.com"
# senha = "UmaSenhaForte!23"
# perfil = "supervisor"

# Se TRUE, sincroniza usuários existentes com os dados acima (reset controlado).
# Use apenas quando precisar alinhar senhas/perfis na Cloud.
BOOTSTRAP_SYNC_EXISTING = "false"

# Caminho do banco (apenas se você estiver usando volume persistente / self-host).
# No Streamlit Cloud, o filesystem é efêmero; prefira um banco externo.
DB_PATH = "cobranca.db"

# Limites de upload (MB)
MAX_UPLOAD_MB_EXCEL = "25"
MAX_UPLOAD_MB_DB = "50"

# Proteção de login (rate-limit)
LOGIN_MAX_TENTATIVAS = "6"
LOGIN_WINDOW_SECONDS = "300"
LOGIN_COOLDOWN_SECONDS = "120"

